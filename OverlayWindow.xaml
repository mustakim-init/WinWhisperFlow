<Window x:Class="WinWhisperFlow.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="80"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
  <Window.Resources>
    <!-- Animated listening bubbles -->
    <Storyboard x:Key="ListenAnim" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="Bubble1"
                       Storyboard.TargetProperty="(Canvas.Left)"
                       To="24" Duration="0:0:0.72" />
      <DoubleAnimation Storyboard.TargetName="Bubble1"
                       Storyboard.TargetProperty="Opacity"
                       To="0.25" Duration="0:0:0.72" />
      <DoubleAnimation Storyboard.TargetName="Bubble2"
                       Storyboard.TargetProperty="(Canvas.Left)"
                       To="78" Duration="0:0:0.86" />
      <DoubleAnimation Storyboard.TargetName="Bubble2"
                       Storyboard.TargetProperty="Opacity"
                       To="0.90" Duration="0:0:0.86" />
      <DoubleAnimation Storyboard.TargetName="Bubble3"
                       Storyboard.TargetProperty="(Canvas.Left)"
                       To="148" Duration="0:0:0.64" />
      <DoubleAnimation Storyboard.TargetName="Bubble3"
                       Storyboard.TargetProperty="Opacity"
                       To="0.35" Duration="0:0:0.64" />
    </Storyboard>

    <!-- M3 glass glow -->
    <DropShadowEffect x:Key="GlassGlow" BlurRadius="32" ShadowDepth="0" Opacity="0.35" Color="#48D7FF" />
  </Window.Resources>

  <!-- M3 Glass card background -->
  <Border CornerRadius="20"
          Background="#D90F172A"
          BorderBrush="#30FFFFFF"
          BorderThickness="1"
          Padding="20,14"
          Effect="{StaticResource GlassGlow}">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Animated blob panel (visible during listening/transcribing) -->
      <Canvas x:Name="BlobPanel" Width="200" Height="48" VerticalAlignment="Center">
        <Ellipse x:Name="Bubble1" Width="36" Height="36" Canvas.Left="0" Canvas.Top="6"
                 Fill="#48D7FF" Opacity="0.70">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Bubble1Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="Bubble2" Width="48" Height="48" Canvas.Left="48" Canvas.Top="0"
                 Fill="#3EE6B5" Opacity="0.65">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Bubble2Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="Bubble3" Width="30" Height="30" Canvas.Left="116" Canvas.Top="9"
                 Fill="#FFD166" Opacity="0.72">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Bubble3Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>
        <!-- Glass bar behind blobs -->
        <Rectangle Width="184" Height="12" Canvas.Left="0" Canvas.Top="18"
                   RadiusX="6" RadiusY="6" Fill="#18FFFFFF" />
      </Canvas>

      <!-- Done panel (success state) -->
      <StackPanel x:Name="DonePanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
        <Border Width="32" Height="32" CornerRadius="10" Background="#1A4ADE80" Margin="0,0,12,0">
          <TextBlock Text="&#x2713;" FontSize="18" FontWeight="Bold"
                     Foreground="#4ADE80"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock x:Name="DoneText" FontSize="15" FontWeight="SemiBold"
                   Foreground="White" VerticalAlignment="Center" TextWrapping="NoWrap" />
      </StackPanel>

      <!-- State text -->
      <TextBlock x:Name="OverlayText"
                 Grid.Column="1"
                 VerticalAlignment="Center"
                 Margin="20,0,0,0"
                 Text="Listening"
                 FontSize="15" FontWeight="SemiBold"
                 Foreground="White" />
    </Grid>
  </Border>
</Window>
